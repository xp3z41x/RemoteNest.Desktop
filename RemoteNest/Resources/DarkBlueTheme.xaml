<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surface ramp: darkest at the base, slightly lighter for elevated containers -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush"         Color="#0A1628" />
    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush"         Color="#0F1E35" />
    <SolidColorBrush x:Key="SystemControlBackgroundAltMediumHighBrush"   Color="#0F1E35" />
    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush"    Color="#132942" />
    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush" Color="#102236" />
    <SolidColorBrush x:Key="SystemControlBackgroundChromeLowBrush"       Color="#0F1E35" />
    <SolidColorBrush x:Key="SystemControlBackgroundListLowBrush"         Color="#132942" />
    <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush"         Color="#1C3A5C" />

    <!-- Borders and dividers — warmer than the surface without hard edges -->
    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush"         Color="#2D4A6E" />
    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumLowBrush"   Color="#3C5A82" />
    <SolidColorBrush x:Key="SystemControlHighlightBaseLowBrush"          Color="#2D4A6E" />

    <!-- Typography -->
    <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush"        Color="#E8F0F8" />
    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush"      Color="#9BB5D0" />
    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumHighBrush"  Color="#C8D8ED" />
    <SolidColorBrush x:Key="SystemControlPageTextBaseHighBrush"          Color="#E8F0F8" />
    <SolidColorBrush x:Key="SystemControlPageTextBaseMediumBrush"        Color="#9BB5D0" />

    <!-- Hover / pressed states in a blue family, not grayscale -->
    <SolidColorBrush x:Key="SystemControlBackgroundListMediumBrush"      Color="#1C3A5C" />
    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush"          Color="#1C3A5C" />
    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush"       Color="#234875" />
    <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush"    Color="#1C3A5C" />

</ResourceDictionary>
