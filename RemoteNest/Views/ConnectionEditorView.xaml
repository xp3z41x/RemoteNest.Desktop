<Window x:Class="RemoteNest.Views.ConnectionEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:converters="clr-namespace:RemoteNest.Converters"
        xmlns:loc="clr-namespace:RemoteNest.Localization"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/app.ico"
        Title="{loc:Str EditorTitle}"
        Width="520" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NotNullToVis" Invert="True" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- General Tab -->
            <TabItem Header="{loc:Str General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="4">
                        <TextBlock Text="{loc:Str NameRequired}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 ui:ControlHelper.PlaceholderText="{loc:Str NamePlaceholder}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding NameError}" Foreground="IndianRed" FontSize="11"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding NameError, Converter={StaticResource NotNullToVis}}" />

                        <TextBlock Text="{loc:Str GroupLabel}" Margin="0,0,0,4" />
                        <ComboBox IsEditable="True" Text="{Binding Group, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableGroups}"
                                  ui:ControlHelper.PlaceholderText="{loc:Str GroupPlaceholder}"
                                  HorizontalAlignment="Stretch" Margin="0,0,0,12" />

                        <TextBlock Text="{loc:Str HostRequired}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                 ui:ControlHelper.PlaceholderText="{loc:Str HostPlaceholder}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding HostError}" Foreground="IndianRed" FontSize="11"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding HostError, Converter={StaticResource NotNullToVis}}" />

                        <TextBlock Text="{loc:Str Port}" Margin="0,0,0,4" />
                        <ui:NumberBox x:Name="PortBox" Minimum="1" Maximum="65535"
                                      SpinButtonPlacementMode="Compact" Margin="0,0,0,12"
                                      ValueChanged="PortBox_ValueChanged" />

                        <TextBlock Text="{loc:Str Username}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12" />

                        <TextBlock Text="{loc:Str Password}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="PasswordField" Margin="0,0,0,12"
                                     PasswordChanged="PasswordField_Changed" />

                        <TextBlock Text="{loc:Str Domain}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12" />

                        <TextBlock Text="{loc:Str Notes}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0,0,0,12" />

                        <ui:ToggleSwitch x:Name="AutoConnectToggle" Header="{loc:Str AutoConnect}"
                                         Toggled="AutoConnectToggle_Toggled" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Display Tab -->
            <TabItem Header="{loc:Str Display}">
                <StackPanel Margin="12">
                    <TextBlock Text="{loc:Str ScreenWidth}" Margin="0,0,0,4" />
                    <ui:NumberBox x:Name="ScreenWidthBox" Minimum="640" Maximum="7680"
                                  SpinButtonPlacementMode="Compact" Margin="0,0,0,12"
                                  ValueChanged="ScreenWidthBox_ValueChanged" />

                    <TextBlock Text="{loc:Str ScreenHeight}" Margin="0,0,0,4" />
                    <ui:NumberBox x:Name="ScreenHeightBox" Minimum="480" Maximum="4320"
                                  SpinButtonPlacementMode="Compact" Margin="0,0,0,12"
                                  ValueChanged="ScreenHeightBox_ValueChanged" />

                    <ui:ToggleSwitch x:Name="FullScreenToggle" Header="{loc:Str FullScreen}" Margin="0,0,0,12"
                                     Toggled="FullScreenToggle_Toggled" />

                    <TextBlock Text="{loc:Str ColorDepth}" Margin="0,0,0,4" />
                    <ComboBox SelectedItem="{Binding ColorDepth}"
                              ItemsSource="{Binding ColorDepths}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>
            </TabItem>

            <!-- Resources Tab -->
            <TabItem Header="{loc:Str Resources}">
                <StackPanel Margin="12">
                    <ui:ToggleSwitch x:Name="RedirectClipboardToggle" Header="{loc:Str ClipboardRedirection}"
                                     Margin="0,0,0,8" Toggled="RedirectClipboardToggle_Toggled" />
                    <ui:ToggleSwitch x:Name="RedirectDrivesToggle" Header="{loc:Str DriveRedirection}"
                                     Margin="0,0,0,8" Toggled="RedirectDrivesToggle_Toggled" />
                    <ui:ToggleSwitch x:Name="RedirectPrintersToggle" Header="{loc:Str PrinterRedirection}"
                                     Margin="0,0,0,8" Toggled="RedirectPrintersToggle_Toggled" />
                    <ui:ToggleSwitch x:Name="RedirectAudioToggle" Header="{loc:Str AudioRedirection}"
                                     Margin="0,0,0,8" Toggled="RedirectAudioToggle_Toggled" />
                    <ui:ToggleSwitch x:Name="UseNlaToggle" Header="{loc:Str NlaToggle}"
                                     Toggled="UseNlaToggle_Toggled" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Str TestConnection}" Command="{Binding TestConnectionCommand}"
                    Margin="0,0,8,0" />
            <Button Content="{loc:Str Save}" Command="{Binding SaveCommand}"
                    Style="{StaticResource RnAccentButtonStyle}" Margin="0,0,8,0" />
            <Button Content="{loc:Str Cancel}" Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
