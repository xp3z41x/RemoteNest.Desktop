<Window x:Class="RemoteNest.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:loc="clr-namespace:RemoteNest.Localization"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/app.ico"
        Title="{loc:Str SettingsTitle}"
        Width="460" Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <ui:ToggleSwitch x:Name="AutoStartToggle"
                             Header="{loc:Str AutoStartWithWindows}"
                             Toggled="AutoStartToggle_Toggled" />
            <TextBlock Text="{loc:Str AutoStartDescription}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />

            <StackPanel Margin="0,24,0,0">
                <TextBlock Text="{loc:Str Theme}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="ThemeComboBox" MinHeight="34" Padding="12,7"
                          SelectionChanged="ThemeComboBox_SelectionChanged"
                          HorizontalAlignment="Stretch" />
                <TextBlock Text="{loc:Str ThemeDescription}" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,6,0,0" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Str Close}" Click="CloseButton_Click"
                    Style="{StaticResource RnAccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
